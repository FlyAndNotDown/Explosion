#include <Platform.esh>

VkBinding(1, 0) cbuffer materialUniform : register(b0) {
    float4 baseColor;
};

#include <Material.esh>

struct FragmentInput {
    float4 position : SV_POSITION;
    float2 uv0 : TEXCOORD0;
};

float4 PSMain(FragmentInput input) : SV_TARGET
{
    return GetBaseColor();
}
